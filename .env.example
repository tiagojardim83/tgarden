# Copy this to .env.local for local `vercel dev` testing, and add the same
# 5 vars in the Vercel dashboard (Project Settings → Environment Variables)
# for production. See ADMIN_SETUP.md for how to get the GitHub App values.

# Password the client uses to log into /admin.
ADMIN_PASSWORD=

# Random string used to sign the admin session cookie. Any long random
# value works — generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# From the GitHub App's settings page (github.com/settings/apps/<name>).
GITHUB_APP_ID=

# From the GitHub App's settings page — "Generate a private key" button.
# Paste the full contents of the downloaded .pem file, including the
# -----BEGIN/END----- lines.
GITHUB_APP_PRIVATE_KEY=

# The numeric ID of the App's installation on the tgarden repo. Visible in
# the URL when viewing the installation, e.g.
# github.com/settings/installations/12345678 -> 12345678
GITHUB_APP_INSTALLATION_ID=
